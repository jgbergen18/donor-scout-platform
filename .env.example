# ─────────────────────────────────────────────────────────────
# LinkedIn Donor Scout — environment template
# Copy to `.env` and fill in. `.env` is gitignored (never commit secrets).
# ─────────────────────────────────────────────────────────────

# Server
PORT=5000
# Where the React client runs (used for OAuth redirect-back + CORS).
CLIENT_URL=http://localhost:5173

# Session — set to any long random string in production.
SESSION_SECRET=change-me-to-a-long-random-string

# ── LinkedIn "Sign In with LinkedIn using OpenID Connect" ───────
# Create an app at https://www.linkedin.com/developers/apps and add the
# "Sign In with LinkedIn using OpenID Connect" product (scopes: openid profile email).
# Auth Redirect URL to register: http://localhost:5000/api/auth/linkedin/callback
# Leave blank to run with the "demo login" fallback only.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=http://localhost:5000/api/auth/linkedin/callback

# ── GitHub enrichment ──────────────────────────────────────────
# Classic Personal Access Token (no scopes needed for public search).
# Optional but strongly recommended: lifts the Search API from 10 -> 30 req/min.
# Create at https://github.com/settings/tokens
GITHUB_TOKEN=

# ── Claude AI (next-gen features: dossiers, in-voice drafting, campaign agent) ──
# Get a key at https://console.anthropic.com. Leave blank to run WITHOUT AI —
# the app degrades to its existing heuristics (like GitHub does without a token).
ANTHROPIC_API_KEY=

# Cost controls — keep AI spend under your provider limit.
#   AI_DAILY_BUDGET_USD: hard cap on estimated AI spend per rolling 24h. Once hit,
#     AI features pause until the window resets. Default 5. Set BELOW your limit.
#   AI_DAILY_BUDGET_PER_ORG_USD: per-tenant daily sub-budget under the global cap
#     above, so one org can't exhaust the shared budget and 429 everyone else.
#     Defaults to AI_DAILY_BUDGET_USD (single-tenant ⇒ no extra limit). On a
#     multi-tenant deployment set this LOWER than the global cap. In-memory only
#     (resets on restart); the persisted global cap remains the hard backstop.
#   AI_MODEL_TIER: 'economy' (DEFAULT — Sonnet+Haiku, cheapest) or 'standard'
#     (Opus+Sonnet, higher quality). Haiku handles the high-volume drafting.
AI_DAILY_BUDGET_USD=5
AI_DAILY_BUDGET_PER_ORG_USD=5
AI_MODEL_TIER=economy

# ── Email delivery (magic-link sign-in + invitations) ──────────────
# Leave blank to run WITHOUT real email — the app logs the link to the console
# (great for local/dev/eval; degrades gracefully like AI/GitHub above).
# For REAL delivery set all three: a supported provider, its API key, and a
# verified From address. Uses the built-in HTTP API (no extra dependency).
#   MAIL_PROVIDER: resend | sendgrid | postmark
MAIL_PROVIDER=
MAIL_PROVIDER_KEY=
MAIL_FROM=
